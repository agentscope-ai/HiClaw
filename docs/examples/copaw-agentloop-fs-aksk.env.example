# Copy the needed lines into your HiClaw manager env file.
# Default location used by the installer and scripts:
#   ~/hiclaw-manager.env
#
# This example enables CoPaw AgentLoop FS memory in local/container mode
# using static AK/SK authentication.

HICLAW_COPAW_AGENTLOOP_FS_MEMORY_ENABLED=true

# Path inside the CoPaw worker container.
HICLAW_COPAW_AGENTLOOP_FS_MOUNT=/tmp/alibabacloud

# AgentLoop memory store name used by the injected CoPaw skill and AGENTS rule.
HICLAW_COPAW_AGENTLOOP_FS_STORE=copaw-default

# Keep CoPaw's built-in memory manager unless you want to force AgentLoop FS only.
HICLAW_COPAW_AGENTLOOP_FS_DISABLE_MEMORY_MANAGER=false

# AgentLoop Memory credentials
HICLAW_COPAW_AGENTLOOP_FS_CMS_WORKSPACE=your-cms-workspace-id
HICLAW_COPAW_AGENTLOOP_FS_CMS_ENDPOINT=
HICLAW_COPAW_AGENTLOOP_FS_ACCESS_KEY_ID=your-access-key-id
HICLAW_COPAW_AGENTLOOP_FS_ACCESS_KEY_SECRET=your-access-key-secret

# Optional STS token. Leave empty for plain AK/SK mode.
HICLAW_COPAW_AGENTLOOP_FS_SECURITY_TOKEN=
